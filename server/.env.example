# Anthropic Claude API Key (required)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Server
PORT=3002
# REQUIRED: generate a strong random token! The server refuses to start with 'dev-token'
# unless ALLOW_DEFAULT_TOKEN=true is set. Generate with:
#   openssl rand -hex 32
# or:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_TOKEN=CHANGE_ME_TO_A_RANDOM_STRING

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Telegram (optional)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Google OAuth2 (enables Gmail, Drive, Tasks, Calendar, Contacts)
# Get credentials from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3002/api/google/callback

# Working directory (where AI can access files)
WORKSPACE_DIR=/storage/emulated/0
